/* Ingredient List Styles */
.list-page {
  padding-bottom: 140rpx;
  background: #F5F7FA;
  min-height: 100vh;
}

.search-bar {
  padding: 16rpx 24rpx;
  background: #fff;
}
.search-input-wrap {
  display: flex;
  align-items: center;
  background: #F5F7FA;
  border-radius: 40rpx;
  padding: 0 20rpx;
}
.search-input {
  flex: 1;
  padding: 16rpx 12rpx;
  font-size: 28rpx;
}
.search-close {
  font-size: 28rpx;
  color: #999;
  padding: 8rpx;
}
.search-icons {
  display: flex;
  justify-content: flex-end;
  gap: 24rpx;
}
.search-icon-btn {
  font-size: 36rpx;
  padding: 8rpx;
}

/* Category Filter */
.cat-filter {
  white-space: nowrap;
  padding: 12rpx 24rpx;
  background: #fff;
  border-bottom: 1rpx solid #F0F0F0;
}
.cat-chip {
  display: inline-block;
  padding: 10rpx 28rpx;
  border-radius: 24rpx;
  font-size: 26rpx;
  color: #666;
  background: #F5F7FA;
  margin-right: 12rpx;
}
.cat-chip.active {
  background: #4A90D9;
  color: #fff;
}

/* Ingredient Rows */
.ingredient-list {
  padding: 16rpx 24rpx;
}
.ingredient-row {
  display: flex;
  align-items: center;
  background: #fff;
  border-radius: 16rpx;
  padding: 20rpx;
  margin-bottom: 12rpx;
  box-shadow: 0 2rpx 8rpx rgba(0,0,0,0.04);
  gap: 16rpx;
}
.row-emoji-wrap {
  width: 70rpx;
  height: 70rpx;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  border: 3rpx solid #EEE;
}
.row-emoji-wrap.status-fresh { border-color: #52C41A; background: #F6FFED; }
.row-emoji-wrap.status-warning { border-color: #FAAD14; background: #FFFBE6; }
.row-emoji-wrap.status-urgent { border-color: #FF4D4F; background: #FFF1F0; }
.row-emoji-wrap.status-expired { border-color: #999; background: #F5F5F5; }
.row-emoji {
  font-size: 36rpx;
}
.row-info {
  flex: 1;
}
.row-name {
  font-size: 30rpx;
  font-weight: 600;
  color: #333;
  display: block;
}
.row-meta {
  font-size: 24rpx;
  color: #999;
  margin-top: 4rpx;
}
.row-right {
  text-align: right;
}
.row-expiry {
  font-size: 22rpx;
  color: #BBB;
  display: block;
  margin-top: 6rpx;
}
.row-delete {
  padding: 8rpx;
  opacity: 0.4;
}
.row-delete:active { opacity: 1; }
