.fridge-page {
  background: linear-gradient(180deg, #E8F4FD 0%, #F5F7FA 30%);
  min-height: 100vh;
  padding-bottom: 120rpx;
}

/* ── Tips Banner ── */
.tips-banner {
  margin: 16rpx 24rpx;
  background: linear-gradient(135deg, #FFF8E1, #FFF3CD);
  border-radius: 20rpx;
  padding: 16rpx 24rpx;
  display: flex;
  align-items: center;
  box-shadow: 0 2rpx 8rpx rgba(0,0,0,0.04);
}
.tips-icon { font-size: 28rpx; margin-right: 10rpx; flex-shrink: 0; }
.tips-text {
  flex: 1;
  font-size: 26rpx;
  color: #8B6914;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}
.tips-dots { display: flex; flex-shrink: 0; margin-left: 12rpx; }
.dot {
  width: 10rpx; height: 10rpx;
  border-radius: 50%;
  background: #DDD;
  margin-left: 8rpx;
}
.dot.active { background: #FAAD14; }

/* ── Fridge ── */
.fridge-wrapper {
  margin: 20rpx 24rpx;
  display: flex;
  justify-content: center;
}
.fridge { width: 100%; max-width: 600rpx; }
.fridge-freezer {
  background: linear-gradient(180deg, #D0D8E0, #BCC4CC);
  height: 60rpx;
  border-radius: 20rpx 20rpx 0 0;
  display: flex;
  align-items: center;
  justify-content: center;
}
.fridge-handle {
  width: 80rpx; height: 10rpx;
  background: #A0A8B0;
  border-radius: 5rpx;
}
.fridge-body {
  background: linear-gradient(180deg, #F8FAFB, #EEF2F5);
  border: 6rpx solid #D0D8E0;
  border-top: none; border-bottom: none;
  min-height: 620rpx;
  position: relative;
  overflow: hidden;
}
.fridge-light {
  position: absolute;
  top: 0; left: 20%; right: 20%;
  height: 60rpx;
  background: linear-gradient(180deg, rgba(255,255,240,0.8), transparent);
  border-radius: 0 0 50% 50%;
}
.shelf {
  position: absolute; left: 0; right: 0;
  height: 3rpx;
  background: linear-gradient(90deg, transparent, rgba(180,190,200,0.4), rgba(180,190,200,0.6), rgba(180,190,200,0.4), transparent);
}
.fridge-legs {
  display: flex;
  justify-content: space-between;
  padding: 0 40rpx;
  background: #D0D8E0;
  height: 16rpx;
  border-radius: 0 0 16rpx 16rpx;
}
.leg {
  width: 40rpx; height: 20rpx;
  background: #B0B8C0;
  border-radius: 0 0 8rpx 8rpx;
}

/* ── Ingredient Cards ── */
.ingredient-card {
  position: absolute;
  display: flex;
  flex-direction: column;
  align-items: center;
  width: 130rpx;
}
.ingredient-card:active { z-index: 10; transform: scale(1.15) !important; }
.freshness-ring {
  width: 90rpx; height: 90rpx;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  background: white;
  box-shadow: 0 4rpx 16rpx rgba(0,0,0,0.08);
  border: 4rpx solid transparent;
}
.freshness-ring.status-fresh { border-color: #52C41A; background: #F6FFED; }
.freshness-ring.status-warning { border-color: #FAAD14; background: #FFFBE6; }
.freshness-ring.status-urgent { border-color: #FF4D4F; background: #FFF1F0; }
.freshness-ring.status-expired { border-color: #999; background: #F5F5F5; }
.emoji-wrap { display: flex; align-items: center; justify-content: center; }
.ingredient-emoji { font-size: 44rpx; line-height: 1; }
.ingredient-name {
  font-size: 22rpx; color: #555;
  margin-top: 6rpx; font-weight: 500;
  text-align: center;
  max-width: 130rpx;
  overflow: hidden; text-overflow: ellipsis; white-space: nowrap;
}
.ingredient-qty { font-size: 20rpx; color: #999; margin-top: 2rpx; }

/* ── Status ── */
.fridge-status {
  position: absolute;
  top: 0; left: 0; right: 0; bottom: 0;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
}
.status-icon { font-size: 100rpx; opacity: 0.5; margin-bottom: 16rpx; }
.status-text { font-size: 30rpx; color: #999; font-weight: 500; }
.status-sub { font-size: 24rpx; color: #BBB; margin-top: 8rpx; }

/* ── Action Area ── */
.action-area {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 0 24rpx;
  margin-top: 16rpx;
}
.add-btn {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 12rpx;
  width: 80%;
  padding: 24rpx;
  background: linear-gradient(135deg, #4A90D9, #357ABD);
  color: #fff;
  border-radius: 48rpx;
  font-size: 30rpx;
  font-weight: 600;
  box-shadow: 0 8rpx 24rpx rgba(74, 144, 217, 0.3);
}
.action-icon { font-size: 32rpx; }
.action-row { display: flex; gap: 24rpx; margin-top: 20rpx; }
.action-btn-sm {
  padding: 14rpx 32rpx;
  background: #fff;
  border-radius: 30rpx;
  font-size: 24rpx;
  color: #666;
  box-shadow: 0 2rpx 8rpx rgba(0,0,0,0.04);
}

/* ── Detail Modal ── */
.modal-mask {
  position: fixed;
  top: 0; left: 0; right: 0; bottom: 0;
  background: rgba(0,0,0,0.4);
  z-index: 1000;
  display: flex;
  align-items: flex-end;
}
.modal-sheet {
  background: #fff;
  border-radius: 32rpx 32rpx 0 0;
  width: 100%;
  padding: 32rpx;
  padding-bottom: calc(32rpx + env(safe-area-inset-bottom));
  animation: slideUp 0.3s ease;
}
@keyframes slideUp {
  from { transform: translateY(100%); }
  to { transform: translateY(0); }
}
.sheet-handle {
  width: 48rpx; height: 6rpx;
  background: #DDD;
  border-radius: 3rpx;
  margin: 0 auto 24rpx;
}
.detail-header {
  display: flex;
  flex-direction: column;
  align-items: center;
  margin-bottom: 24rpx;
}
.detail-emoji-wrap {
  width: 100rpx; height: 100rpx;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: 12rpx;
  border: 4rpx solid;
}
.detail-emoji-wrap.status-fresh { border-color: #52C41A; background: #F6FFED; }
.detail-emoji-wrap.status-warning { border-color: #FAAD14; background: #FFFBE6; }
.detail-emoji-wrap.status-urgent { border-color: #FF4D4F; background: #FFF1F0; }
.detail-emoji-wrap.status-expired { border-color: #999; background: #F5F5F5; }
.detail-emoji { font-size: 50rpx; }
.detail-name { font-size: 34rpx; font-weight: 600; color: #333; }
.detail-badge {
  margin-top: 8rpx;
  padding: 4rpx 20rpx;
  border-radius: 20rpx;
  font-size: 22rpx;
}
.detail-badge.badge-fresh { background: #F6FFED; color: #52C41A; }
.detail-badge.badge-warning { background: #FFFBE6; color: #FAAD14; }
.detail-badge.badge-urgent { background: #FFF1F0; color: #FF4D4F; }
.detail-badge.badge-expired { background: #F5F5F5; color: #999; }

.detail-info { margin-bottom: 24rpx; }
.info-row {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 16rpx 0;
  border-bottom: 1rpx solid #F5F5F5;
}
.info-label { font-size: 28rpx; color: #888; }
.info-value { font-size: 28rpx; color: #333; font-weight: 500; }
.freshness-bar-wrap {
  display: flex; align-items: center; gap: 12rpx;
}
.freshness-bar {
  width: 160rpx; height: 10rpx;
  background: #EEE;
  border-radius: 5rpx;
  overflow: hidden;
}
.freshness-fill { height: 100%; border-radius: 5rpx; transition: width 0.5s ease; }
.freshness-fill.status-fresh { background: #52C41A; }
.freshness-fill.status-warning { background: #FAAD14; }
.freshness-fill.status-urgent { background: #FF4D4F; }
.freshness-fill.status-expired { background: #999; }
.freshness-pct { font-size: 24rpx; color: #888; }

.detail-actions {
  display: flex; gap: 24rpx;
}
.detail-actions .btn {
  padding: 20rpx;
  border-radius: 40rpx;
  font-size: 28rpx;
}
