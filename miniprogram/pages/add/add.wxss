/* Add Page Styles */
.add-page {
  background: #F5F7FA;
  min-height: 100vh;
  display: flex;
  flex-direction: column;
}

/* Mode Tabs */
.mode-tabs {
  display: flex;
  background: #fff;
  padding: 16rpx 24rpx;
  gap: 16rpx;
  box-shadow: 0 2rpx 8rpx rgba(0,0,0,0.04);
}
.mode-tab {
  flex: 1;
  text-align: center;
  padding: 16rpx;
  border-radius: 30rpx;
  font-size: 28rpx;
  color: #888;
  background: #F5F7FA;
  transition: all 0.2s;
}
.mode-tab.active {
  background: #4A90D9;
  color: #fff;
  font-weight: 600;
}

/* ── Chat Mode ── */
.chat-mode {
  flex: 1;
  display: flex;
  flex-direction: column;
}

.parsed-list {
  padding: 20rpx 24rpx;
}
.parsed-header {
  margin-bottom: 16rpx;
}
.parsed-title {
  font-size: 26rpx;
  color: #888;
}
.parsed-card {
  background: #fff;
  border-radius: 16rpx;
  padding: 16rpx 20rpx;
  margin-bottom: 12rpx;
  box-shadow: 0 2rpx 8rpx rgba(0,0,0,0.04);
  border-left: 4rpx solid #4A90D9;
}
.parsed-main {
  display: flex;
  align-items: center;
  gap: 12rpx;
}
.parsed-emoji {
  font-size: 40rpx;
}
.parsed-info {
  flex: 1;
  display: flex;
  flex-direction: column;
}
.parsed-name {
  font-size: 30rpx;
  font-weight: 600;
  color: #333;
}
.parsed-meta {
  font-size: 24rpx;
  color: #999;
  margin-top: 4rpx;
}
.parsed-remove {
  font-size: 28rpx;
  color: #CCC;
  padding: 8rpx;
}
.parsed-actions {
  display: flex;
  gap: 24rpx;
  margin-top: 12rpx;
  padding-top: 12rpx;
  border-top: 1rpx solid #F5F5F5;
}
.parsed-edit {
  font-size: 22rpx;
  color: #4A90D9;
  padding: 4rpx 0;
}

.confirm-btn {
  width: 100%;
  margin-top: 16rpx;
  padding: 24rpx;
  border-radius: 40rpx;
  font-size: 30rpx;
}

/* Chat Area */
.chat-area {
  flex: 1;
  padding: 24rpx;
  display: flex;
  flex-direction: column;
  justify-content: center;
  align-items: center;
}
.chat-hint {
  text-align: center;
  padding: 40rpx;
}
.hint-icon {
  font-size: 80rpx;
  display: block;
  margin-bottom: 16rpx;
}
.hint-title {
  font-size: 30rpx;
  color: #555;
  font-weight: 500;
  display: block;
  margin-bottom: 20rpx;
}
.hint-examples {
  font-size: 24rpx;
  color: #BBB;
  display: block;
  margin-bottom: 12rpx;
}
.hint-example {
  font-size: 24rpx;
  color: #AAA;
  display: block;
  padding: 8rpx 0;
  background: #fff;
  border-radius: 8rpx;
  margin-bottom: 8rpx;
  padding: 12rpx 16rpx;
}
.chat-loading {
  text-align: center;
}
.loading-text {
  font-size: 26rpx;
  color: #999;
  display: block;
  margin-top: 16rpx;
}

/* Chat Input Bar */
.chat-input-bar {
  display: flex;
  padding: 16rpx 24rpx;
  padding-bottom: calc(16rpx + env(safe-area-inset-bottom));
  background: #fff;
  gap: 12rpx;
  border-top: 1rpx solid #F0F0F0;
}
.chat-input {
  flex: 1;
  background: #F5F7FA;
  border-radius: 40rpx;
  padding: 18rpx 28rpx;
  font-size: 28rpx;
}
.send-btn {
  background: #4A90D9;
  color: #fff;
  border-radius: 40rpx;
  padding: 18rpx 32rpx;
  font-size: 28rpx;
  border: none;
}
.send-btn[disabled] {
  background: #CCC;
  color: #fff;
}

/* ── Tag Mode ── */
.tag-mode {
  flex: 1;
  display: flex;
  flex-direction: column;
}
.cat-tabs {
  white-space: nowrap;
  padding: 16rpx 24rpx;
  background: #fff;
}
.cat-tab {
  display: inline-block;
  padding: 12rpx 32rpx;
  border-radius: 24rpx;
  font-size: 26rpx;
  color: #666;
  background: #F5F7FA;
  margin-right: 12rpx;
}
.cat-tab.active {
  background: #4A90D9;
  color: #fff;
}
.tag-grid {
  flex: 1;
  display: flex;
  flex-wrap: wrap;
  padding: 20rpx;
  gap: 12rpx;
  align-content: flex-start;
}
.tag-item {
  width: calc(25% - 9rpx);
  background: #fff;
  border-radius: 16rpx;
  padding: 20rpx 8rpx;
  text-align: center;
  box-shadow: 0 2rpx 8rpx rgba(0,0,0,0.04);
  transition: all 0.2s;
}
.tag-item:active {
  transform: scale(0.95);
  background: #F0F7FF;
}
.tag-emoji {
  font-size: 44rpx;
  display: block;
}
.tag-name {
  font-size: 24rpx;
  color: #555;
  display: block;
  margin-top: 6rpx;
}
.tag-expiry {
  font-size: 20rpx;
  color: #BBB;
  display: block;
  margin-top: 2rpx;
}

/* Selected Tags */
.selected-section {
  padding: 16rpx 24rpx;
  padding-bottom: calc(24rpx + env(safe-area-inset-bottom));
  background: #fff;
  border-top: 1rpx solid #F0F0F0;
}
.selected-header {
  font-size: 24rpx;
  color: #999;
  margin-bottom: 12rpx;
}
.selected-tags {
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
  margin-bottom: 16rpx;
}
.selected-tag {
  background: #F0F7FF;
  border: 2rpx solid #4A90D9;
  border-radius: 24rpx;
  padding: 8rpx 20rpx;
  font-size: 24rpx;
  color: #4A90D9;
  display: flex;
  align-items: center;
  gap: 8rpx;
}
.selected-remove {
  font-size: 20rpx;
  color: #999;
  padding: 2rpx;
}
.selected-section .confirm-btn {
  width: 100%;
}

/* ── Tag Modal ── */
.modal-mask {
  position: fixed;
  top: 0; left: 0; right: 0; bottom: 0;
  background: rgba(0,0,0,0.4);
  display: flex;
  align-items: center;
  justify-content: center;
  z-index: 1000;
}
.tag-modal {
  background: #fff;
  border-radius: 24rpx;
  width: 560rpx;
  padding: 32rpx;
}
.tag-modal-header {
  text-align: center;
  margin-bottom: 24rpx;
}
.tag-modal-emoji {
  font-size: 64rpx;
  display: block;
}
.tag-modal-name {
  font-size: 32rpx;
  font-weight: 600;
  color: #333;
  margin-top: 8rpx;
}
.tag-modal-body {
  margin-bottom: 24rpx;
}
.form-group {
  display: flex;
  align-items: center;
  gap: 16rpx;
  margin-bottom: 16rpx;
}
.form-label {
  font-size: 28rpx;
  color: #666;
  width: 100rpx;
}
.form-input {
  flex: 1;
  background: #F5F7FA;
  border-radius: 12rpx;
  padding: 16rpx 20rpx;
  font-size: 28rpx;
  text-align: center;
}
.tag-modal-footer {
  display: flex;
  gap: 20rpx;
}
.tag-modal-footer .btn {
  padding: 20rpx;
  border-radius: 40rpx;
}
