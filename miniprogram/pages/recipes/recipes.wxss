.recipes-page {
  background: #F5F7FA;
  min-height: 100vh;
  padding-bottom: 140rpx;
}

/* Config Panel */
.config-panel {
  background: #fff;
  margin: 16rpx 24rpx;
  border-radius: 20rpx;
  padding: 24rpx;
  box-shadow: 0 2rpx 12rpx rgba(0,0,0,0.04);
}
.config-row { display: flex; gap: 24rpx; margin-bottom: 16rpx; }
.config-item { flex: 1; }
.config-label { font-size: 26rpx; color: #666; display: block; margin-bottom: 4rpx; }
.dish-hint { font-size: 20rpx; color: #BBB; display: block; margin-bottom: 2rpx; }
.cuisine-picker {
  background: #F5F7FA;
  border-radius: 12rpx;
  padding: 18rpx 20rpx;
  font-size: 28rpx;
  color: #333;
  text-align: center;
}

/* Mode Toggle */
.mode-toggle {
  background: #F0F7FF;
  border-radius: 12rpx;
  padding: 18rpx 20rpx;
  font-size: 26rpx;
  text-align: center;
  color: #4A90D9;
}
.mode-toggle.active {
  background: #FFF1F0;
  color: #FF4D4F;
  border: 2rpx solid #FF4D4F;
}

/* Ingredient Picker Block */
.ing-picker-block {
  margin-bottom: 16rpx;
  border: 2rpx solid #EEE;
  border-radius: 16rpx;
  overflow: hidden;
}
.ing-picker-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 20rpx;
  font-size: 26rpx;
  color: #555;
}
.ing-picker-count { color: #4A90D9; font-weight: 500; }
.ing-picker-arrow { color: #BBB; font-size: 22rpx; }
.ing-picker-body {
  padding: 0 16rpx 16rpx;
  background: #FAFBFC;
  border-top: 1rpx solid #F0F0F0;
}
.ing-pick-actions {
  text-align: right;
  padding: 10rpx 4rpx;
  font-size: 24rpx;
  color: #4A90D9;
}
.ing-pick-grid {
  display: flex;
  flex-wrap: wrap;
  gap: 10rpx;
  max-height: 220rpx;
  overflow-y: auto;
}
.ing-pick-chip {
  display: flex;
  align-items: center;
  gap: 4rpx;
  background: #fff;
  border: 2rpx solid #EEE;
  border-radius: 20rpx;
  padding: 8rpx 16rpx;
  font-size: 24rpx;
  color: #666;
}
.ing-pick-chip.selected {
  background: #F0F7FF;
  border-color: #4A90D9;
  color: #4A90D9;
}
.ing-check-mark {
  font-size: 18rpx;
  color: #4A90D9;
  font-weight: 700;
}
.ing-pick-empty {
  text-align: center;
  padding: 24rpx;
  font-size: 24rpx;
  color: #BBB;
}

.generate-btn {
  width: 100%;
  padding: 24rpx;
  border-radius: 44rpx;
  font-size: 30rpx;
  margin-top: 8rpx;
}
.no-token-hint {
  text-align: center;
  margin-top: 16rpx;
  font-size: 24rpx;
  color: #FAAD14;
}

/* Section Toggle */
.section-toggle {
  text-align: center;
  padding: 20rpx;
  font-size: 26rpx;
  color: #4A90D9;
  font-weight: 500;
}

/* Recipe Cards */
.recipe-list { padding: 0 24rpx; }
.recipe-card {
  background: #fff;
  border-radius: 16rpx;
  padding: 24rpx;
  margin-bottom: 16rpx;
  box-shadow: 0 2rpx 12rpx rgba(0,0,0,0.04);
}
.recipe-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 16rpx;
}
.recipe-name { font-size: 32rpx; font-weight: 700; color: #333; flex: 1; }
.recipe-difficulty {
  font-size: 22rpx;
  color: #4A90D9;
  background: #F0F7FF;
  padding: 4rpx 16rpx;
  border-radius: 12rpx;
  margin-left: 12rpx;
}
.recipe-ingredients {
  display: flex;
  flex-wrap: wrap;
  gap: 8rpx;
  margin-bottom: 12rpx;
}
.recipe-ing {
  background: #F6FFED;
  border-radius: 16rpx;
  padding: 6rpx 14rpx;
  font-size: 24rpx;
  color: #555;
}
.recipe-ing.missing { background: #FFF1F0; }
.recipe-steps-preview {
  font-size: 24rpx;
  color: #999;
  line-height: 1.6;
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
  overflow: hidden;
  margin-bottom: 8rpx;
}
.recipe-footer {
  display: flex;
  justify-content: space-between;
  align-items: center;
}
.save-star { font-size: 36rpx; padding: 8rpx; }
.save-star.saved { color: #FAAD14; }
.save-star:not(.saved) { color: #DDD; }
.detail-link { font-size: 22rpx; color: #BBB; }

/* Loading hint */
.loading-hint {
  display: block;
  text-align: center;
  margin-top: 16rpx;
  font-size: 26rpx;
  color: #999;
}

/* Saved Recipes */
.saved-section { padding: 24rpx; }
.saved-card {
  background: #fff;
  border-radius: 12rpx;
  padding: 16rpx 20rpx;
  margin-bottom: 12rpx;
}
.saved-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 8rpx;
}
.saved-name { font-size: 28rpx; font-weight: 600; color: #333; }
.saved-star { font-size: 28rpx; }
.saved-steps {
  font-size: 24rpx;
  color: #999;
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
  overflow: hidden;
}
