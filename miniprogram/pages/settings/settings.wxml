<view class="page-container settings-page">

  <!-- Token Section -->
  <view class="settings-section">
    <view class="section-title">DeepSeek API Token</view>
    <view class="section-desc">Token 仅保存在手机本地，不会上传到服务器</view>

    <view class="token-status" wx:if="{{hasToken}}">
      <view class="status-dot green"></view>
      <text>已配置: {{tokenMasked}}</text>
      <text class="status-toggle" bindtap="toggleShowToken">{{showToken ? '隐藏' : '查看'}}</text>
    </view>
    <view class="token-status" wx:else>
      <view class="status-dot red"></view>
      <text>未配置</text>
    </view>

    <view class="token-input-wrap">
      <input
        class="token-input"
        placeholder="输入 DeepSeek API Token (sk-...)"
        value="{{showToken ? token : ''}}"
        password="{{!showToken}}"
        bindinput="onTokenInput"
      />
    </view>

    <view class="token-actions">
      <button class="btn btn-primary flex-1" bindtap="saveToken">保存</button>
      <button class="btn btn-outline flex-1" style="color:#FF4D4F;border-color:#FF4D4F;" bindtap="clearToken" wx:if="{{hasToken}}">清除</button>
    </view>

    <button class="btn btn-outline test-ds-btn" bindtap="testDeepSeek">测试 Token 是否可用</button>
    <view class="token-howto" wx:if="{{!hasToken}}">
      <text>如何获取？访问 platform.deepseek.com → API Keys → 创建</text>
    </view>
  </view>

  <!-- Server Section -->
  <view class="settings-section">
    <view class="section-title">后端服务地址</view>
    <view class="server-trouble">
      <text>⚠️ 手机预览须知：</text>
      <text>1. 确保手机和电脑在同一 WiFi</text>
      <text>2. 将地址改为电脑的局域网 IP（后端启动时会显示）</text>
      <text>3. 微信开发者工具需勾选"不校验合法域名"</text>
    </view>
    <view class="input-row">
      <input class="server-input" placeholder="http://192.168.x.x:5000" value="{{apiBase}}" bindinput="onApiBaseInput"/>
      <button class="btn btn-primary" style="padding:14rpx 28rpx;font-size:24rpx;" bindtap="saveApiBase">保存</button>
    </view>
    <view class="server-hint">
      <text>当前: {{apiBase}}</text>
      <text class="conn-btn" bindtap="testConnection">测试连接</text>
    </view>
  </view>

  <!-- About -->
  <view class="settings-section">
    <view class="section-title">关于</view>
    <view class="about-text">
      <text>AI 冰箱管家 v1.0</text>
      <text>Powered by CXY</text>
    </view>
  </view>

  <custom-tab-bar></custom-tab-bar>
</view>
